; @everway packages resolve from the n2y Azure DevOps Artifacts feed.
; Everything else stays on the public npm registry.
@everway:registry=https://pkgs.dev.azure.com/n2y/_packaging/n2y%40Local/npm/registry/

; Auth — PAT (Packaging: Read), base64-encoded, supplied via env var.
; Set it with:  export AZURE_NPM_PAT=$(echo -n 'YOUR_RAW_PAT' | base64)
//pkgs.dev.azure.com/n2y/_packaging/n2y%40Local/npm/registry/:username=n2y
//pkgs.dev.azure.com/n2y/_packaging/n2y%40Local/npm/registry/:_password=${AZURE_NPM_PAT}
//pkgs.dev.azure.com/n2y/_packaging/n2y%40Local/npm/registry/:email=npm@n2y.com
//pkgs.dev.azure.com/n2y/_packaging/n2y%40Local/npm/:username=n2y
//pkgs.dev.azure.com/n2y/_packaging/n2y%40Local/npm/:_password=${AZURE_NPM_PAT}
//pkgs.dev.azure.com/n2y/_packaging/n2y%40Local/npm/:email=npm@n2y.com
